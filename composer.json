{
    "name": "zaeem2396/runtime-shield",
    "description": "RuntimeShield — runtime protection for PHP / Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "RuntimeShield\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RuntimeShield\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RuntimeShield\\Laravel\\Providers\\RuntimeShieldServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html build/coverage",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "php-cs-fixer fix",
        "format:test": "php-cs-fixer fix --dry-run --diff",
        "pre-check": ["@format", "@analyse", "@test"]
    }
}
